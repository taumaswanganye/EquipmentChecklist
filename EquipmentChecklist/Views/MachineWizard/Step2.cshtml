@model EquipmentChecklist.Controllers.WizardMachineData
@{
    ViewData["Title"] = "Create Vehicle/Machine – Step 2";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Page header -->
<div style="margin-bottom:6px">
    <h2 style="font-size:22px;font-weight:700;color:var(--text-main);margin:0">CREATE VEHICLE/MACHINE</h2>
    <p style="font-size:12px;color:var(--text-muted);margin:2px 0 0">Vehicle/Machine</p>
</div>

@await Html.PartialAsync("_WizardProgress", 2)

<div style="padding-top:12px">

    <!-- Create Items button -->
    <div style="display:flex;justify-content:flex-end;margin-bottom:12px">
        <button type="button" onclick="openModal()" class="btn btn-primary" style="font-size:13px;padding:8px 20px">
            + Create Items
        </button>
    </div>

    <!-- Items table -->
    <div style="background:var(--steel-mid);border:1px solid var(--steel-border);border-radius:10px;overflow:hidden;margin-bottom:20px">
        <table class="data-table" data-paginate="5" style="font-size:12px">
            <thead>
                <tr>
                    <th style="width:48px">Id</th>
                    <th>Name</th>
                    <th style="width:70px">Icon</th>
                    <th style="width:80px">Is Critical</th>
                    <th>Status</th>
                    <th>Action</th>
                    <th>RCondition</th>
                    <th>WCondition</th>
                    <th style="width:64px">Heading</th>
                    <th style="width:56px">Action</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="10" style="text-align:center;color:var(--text-muted);padding:24px;font-style:italic">
                            No items yet. Click "Create Items" to add checklist items.
                        </td>
                    </tr>
                }
                @for (int i = 0; i < Model.Items.Count; i++)
                {
                    var item = Model.Items[i];
                    var isCrit = item.IsNoGoItem;
                    var dotColor = isCrit ? "#ef4444" : "#f59e0b";
                    <tr>
                        <td>@(i + 1)</td>
                        <td><strong>@item.ItemName</strong></td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.IconPath))
                            {
                                <img src="/@item.IconPath" alt="icon"
                                     style="width:36px;height:36px;object-fit:contain;border:1px solid var(--steel-border);border-radius:4px;background:#fff;padding:2px" />
                            }
                            else
                            {
                                <div style="width:36px;height:36px;background:var(--steel-dark);border:1px solid var(--steel-border);border-radius:4px;display:flex;align-items:center;justify-content:center;color:var(--text-muted);font-size:18px">—</div>
                            }
                        </td>
                        <td>
                            <span class="badge @(isCrit ? "badge-nogo" : "badge-go")" style="font-size:10px">
                                @(isCrit ? "Yes" : "No")
                            </span>
                        </td>
                        <td style="color:var(--text-muted)">@(item.StatusLabel is { Length: > 0 } s ? s : "–")</td>
                        <td style="max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"
                            title="@item.Action">@(item.Action is { Length: > 0 } ? item.Action[..Math.Min(item.Action.Length, 50)] + (item.Action.Length > 50 ? "…" : "") : "–")</td>
                        <td style="max-width:140px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"
                            title="@item.InOrderCondition">@(item.InOrderCondition is { Length: > 0 } ic ? ic[..Math.Min(ic.Length,40)] + (ic.Length>40?"…":"") : "–")</td>
                        <td style="max-width:140px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"
                            title="@item.DefectCondition">@(item.DefectCondition is { Length: > 0 } dc ? dc[..Math.Min(dc.Length,40)] + (dc.Length>40?"…":"") : "–")</td>
                        <td>
                            <div style="width:22px;height:22px;border-radius:50%;background:@dotColor;margin:auto"></div>
                        </td>
                        <td>
                            <!-- Standalone remove form -->
                            <form id="removeForm_@i" method="post" action="/Admin/CreateMachineWizard/RemoveItem" style="display:inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="index" value="@i" />
                                <button type="submit" class="btn btn-ghost btn-sm"
                                        style="color:var(--red-nogo);border:none;padding:2px 6px;font-size:14px"
                                        onclick="return confirm('Remove this item?')">✕</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Back / Next -->
    <div style="display:flex;justify-content:space-between">
        <a href="/Admin/CreateMachineWizard" class="btn btn-ghost" style="min-width:100px">← Back</a>
        <a href="/Admin/CreateMachineWizard/Step3" class="btn btn-primary" style="min-width:100px">Next ➜</a>
    </div>
</div>

<!-- ════ MODAL ════════════════════════════════════════════════════════════════ -->
<div id="itemModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:1000;align-items:center;justify-content:center">
    <div style="background:var(--steel-mid);border:1px solid var(--steel-border);border-radius:12px;width:680px;max-width:96vw;max-height:92vh;overflow-y:auto;padding:0">

        <!-- Modal header -->
        <div style="padding:16px 24px;border-bottom:1px solid var(--steel-border);display:flex;justify-content:space-between;align-items:center">
            <h3 style="margin:0;font-size:16px;font-weight:700">Create Machine Item</h3>
            <button type="button" onclick="closeModal()" style="background:none;border:none;color:var(--text-muted);font-size:22px;cursor:pointer;line-height:1">×</button>
        </div>

        <form method="post" action="/Admin/CreateMachineWizard/AddItem" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div style="padding:20px 24px;display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px">

                <!-- Name -->
                <div class="form-group" style="margin:0">
                    <label class="form-label">Name <span style="color:var(--red-nogo)">*</span></label>
                    <input type="text" name="itemName" class="form-control" placeholder="Item name" required />
                </div>

                <!-- Status -->
                <div class="form-group" style="margin:0">
                    <label class="form-label">Status</label>
                    <input type="text" name="statusLabel" class="form-control"
                           placeholder="e.g. Go till next Service" />
                </div>

                <!-- Upload Icon -->
                <div class="form-group" style="margin:0">
                    <label class="form-label">Upload Icon</label>
                    <input type="file" name="iconFile" accept="image/*" class="form-control"
                           style="padding:4px 8px;font-size:12px"
                           onchange="previewIcon(this)" />
                    <div id="iconPreview" style="margin-top:6px;display:none">
                        <img id="iconPreviewImg" style="width:40px;height:40px;object-fit:contain;border:1px solid var(--steel-border);border-radius:4px;background:#fff;padding:2px" />
                        <span id="iconPreviewName" style="font-size:11px;color:var(--text-muted);margin-left:6px"></span>
                    </div>
                </div>

                <!-- ACTION -->
                <div class="form-group" style="margin:0;grid-column:1/-1">
                    <label class="form-label">ACTION <span style="color:var(--red-nogo)">*</span></label>
                    <textarea name="action" class="form-control" rows="3"
                              placeholder="What the operator must do / check..."
                              required></textarea>
                </div>

                <!-- IN ORDER 'R' -->
                <div class="form-group" style="margin:0;grid-column:1/2">
                    <label class="form-label">IN ORDER <span style="color:#22c55e">'R'</span></label>
                    <textarea name="inOrderCondition" class="form-control" rows="4"
                              placeholder="Describe what 'In Order' looks like..."></textarea>
                </div>

                <!-- DEFECT 'W' -->
                <div class="form-group" style="margin:0;grid-column:2/-1">
                    <label class="form-label">DEFECT <span style="color:#ef4444">'W'</span></label>
                    <textarea name="defectCondition" class="form-control" rows="4"
                              placeholder="Describe what a defect looks like..."></textarea>
                </div>

                <!-- Is Critical -->
                <div style="grid-column:1/-1;padding:10px 14px;background:var(--steel-dark);border:1px solid var(--steel-border);border-radius:6px">
                    <p style="color:var(--red-nogo);font-size:12px;margin:0 0 8px">
                        Is this part critical for the safe operation of the machine?
                        Please click <strong>Yes</strong> if it is critical, or <strong>No</strong> if it is not.
                    </p>
                    <div style="display:flex;gap:20px">
                        <label style="display:flex;align-items:center;gap:6px;cursor:pointer;font-size:13px">
                            <input type="radio" name="isNoGoItem" value="true" style="accent-color:var(--red-nogo)" />
                            <span>Yes</span>
                        </label>
                        <label style="display:flex;align-items:center;gap:6px;cursor:pointer;font-size:13px">
                            <input type="radio" name="isNoGoItem" value="false" checked style="accent-color:var(--green-go)" />
                            <span>No</span>
                        </label>
                    </div>
                </div>
            </div>

            <!-- Modal footer -->
            <div style="padding:14px 24px;border-top:1px solid var(--steel-border);display:flex;justify-content:flex-end;gap:10px">
                <button type="button" onclick="closeModal()" class="btn btn-ghost">Close</button>
                <button type="submit" class="btn btn-primary">Save Item</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
const modal = document.getElementById('itemModal');

function openModal() {
    modal.style.display = 'flex';
    document.body.style.overflow = 'hidden';
}

function closeModal() {
    modal.style.display = 'none';
    document.body.style.overflow = '';
}

// Close on backdrop click
modal.addEventListener('click', function(e) {
    if (e.target === modal) closeModal();
});

// Icon preview
function previewIcon(input) {
    const preview = document.getElementById('iconPreview');
    const img     = document.getElementById('iconPreviewImg');
    const name    = document.getElementById('iconPreviewName');
    if (input.files && input.files[0]) {
        const file = input.files[0];
        const reader = new FileReader();
        reader.onload = e => {
            img.src = e.target.result;
            name.textContent = file.name;
            preview.style.display = 'flex';
            preview.style.alignItems = 'center';
        };
        reader.readAsDataURL(file);
    } else {
        preview.style.display = 'none';
    }
}
</script>
}
