@{
    ViewData["Title"] = "Order Submitted";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var orderRef  = TempData["OrderRef"]   as string ?? "–";
    var count     = TempData["OrderCount"] as int?   ?? 0;
    var email     = TempData["OrderEmail"] as string;
}

<div style="max-width:560px;margin:0 auto;text-align:center;padding-top:32px">

    <div class="order-success-banner" style="text-align:left;margin-bottom:32px">
        <div class="order-success-icon">✅</div>
        <div>
            <strong style="font-size:16px;color:var(--green-go)">Order Submitted Successfully</strong>
            <p style="font-size:13px;color:var(--text-muted);margin-top:4px">
                Reference: <span style="font-family:var(--font-mono);color:var(--text-primary)">@orderRef</span>
            </p>
        </div>
    </div>

    <div style="background:var(--steel-mid);border:1px solid var(--steel-border);border-radius:10px;padding:24px;margin-bottom:24px">
        <div style="font-size:52px;margin-bottom:12px">📦</div>
        <h2 style="font-size:22px;margin-bottom:8px">@count part order@(count > 1 ? "s" : "") placed</h2>
        <p style="color:var(--text-muted);margin-bottom:16px">
            All defect orders have been updated to <strong style="color:var(--amber)">Awaiting Parts</strong> status.
        </p>

        @if (!string.IsNullOrEmpty(email))
        {
            <div style="background:var(--green-glow);border:1px solid var(--green-dark);border-radius:8px;padding:12px 16px;font-size:13px;margin-bottom:16px">
                📧 Confirmation email sent to <strong>@email</strong>
            </div>
        }
        else
        {
            <div style="background:var(--steel-light);border:1px solid var(--steel-border);border-radius:8px;padding:12px 16px;font-size:13px;color:var(--text-muted);margin-bottom:16px">
                No confirmation email sent (no email address provided).
            </div>
        }

        <div style="display:flex;gap:10px;justify-content:center;flex-wrap:wrap">
            <a href="/Admin/Mechanic/Cart" class="btn btn-primary">View All Defects</a>
            <a href="/Admin" class="btn btn-ghost">← Fleet Dashboard</a>
        </div>
    </div>

    <p style="font-size:12px;color:var(--text-muted)">
        Parts will be sourced by the procurement team and delivered to the workshop.
        Mechanics can mark repairs as complete once parts arrive.
    </p>
</div>
