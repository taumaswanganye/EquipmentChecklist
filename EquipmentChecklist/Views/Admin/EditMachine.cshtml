@model EquipmentChecklist.Models.Machine
@using EquipmentChecklist.Models
@{
    ViewData["Title"] = "Edit Machine";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div style="margin-bottom:16px">
    <a href="/Admin" class="btn btn-ghost" style="font-size:12px">← Back to Fleet</a>
</div>

<div style="display:flex;justify-content:center">
    <div style="width:100%;max-width:680px;background:var(--steel-mid);border:1px solid var(--steel-border);border-radius:10px;overflow:hidden">

        <div style="padding:16px 24px;border-bottom:1px solid var(--steel-border);display:flex;justify-content:space-between;align-items:center">
            <div>
                <h2 style="font-size:18px;font-weight:700;margin:0">Edit Machine</h2>
                <p style="font-size:12px;color:var(--text-muted);margin:2px 0 0">@Model.MachineNumber – @Model.MachineName</p>
            </div>
            <a href="/Admin/ManageItems/@Model.Id" class="btn btn-ghost" style="font-size:12px">
                📋 Manage Checklist Items
            </a>
        </div>

        <form method="post" action="/Admin/EditMachine">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Id" value="@Model.Id" />

            @if (!ViewData.ModelState.IsValid)
            {
                <div style="margin:16px 24px 0;padding:10px 14px;background:#450a0a;border:1px solid #7f1d1d;border-radius:6px;color:#fca5a5;font-size:13px">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div>@error.ErrorMessage</div>
                    }
                </div>
            }

            <div style="padding:24px;display:grid;grid-template-columns:1fr 1fr;gap:16px">

                <!-- Machine Name -->
                <div class="form-group" style="margin:0">
                    <label class="form-label">Machine/Vehicle Name <span style="color:var(--red-nogo)">*</span></label>
                    <input type="text" name="MachineName" class="form-control"
                           value="@Model.MachineName" required maxlength="100" />
                </div>

                <!-- Machine Number -->
                <div class="form-group" style="margin:0">
                    <label class="form-label">Machine FG/Nr <span style="color:var(--red-nogo)">*</span></label>
                    <input type="text" name="MachineNumber" class="form-control"
                           value="@Model.MachineNumber" required maxlength="50"
                           style="@(ViewData.ModelState["MachineNumber"]?.Errors.Count > 0 ? "border-color:#ef4444;" : "")" />
                    @if (ViewData.ModelState["MachineNumber"]?.Errors.Count > 0)
                    {
                        <small style="color:#fca5a5;font-size:11px">
                            @ViewData.ModelState["MachineNumber"]!.Errors[0].ErrorMessage
                        </small>
                    }
                </div>

                <!-- Type -->
                <div class="form-group" style="margin:0">
                    <label class="form-label">Type <span style="color:var(--red-nogo)">*</span></label>
                    <select name="Type" class="form-control" required>
                        <option value="1"  @(Model.Type==MachineType.ADT               ?"selected":"")>ADT – Articulated Dump Truck</option>
                        <option value="2"  @(Model.Type==MachineType.ArticulatedWaterTruck?"selected":"")>Articulated Water Truck</option>
                        <option value="3"  @(Model.Type==MachineType.DieselBowser      ?"selected":"")>Diesel Bowser</option>
                        <option value="4"  @(Model.Type==MachineType.Drills            ?"selected":"")>Drills</option>
                        <option value="5"  @(Model.Type==MachineType.Excavator         ?"selected":"")>Excavator</option>
                        <option value="6"  @(Model.Type==MachineType.FEL               ?"selected":"")>FEL – Front End Loader</option>
                        <option value="7"  @(Model.Type==MachineType.Forklift          ?"selected":"")>Forklift</option>
                        <option value="8"  @(Model.Type==MachineType.Grader            ?"selected":"")>Grader</option>
                        <option value="9"  @(Model.Type==MachineType.LDV               ?"selected":"")>LDV / Light Vehicle</option>
                        <option value="10" @(Model.Type==MachineType.SRVWaterBowser    ?"selected":"")>SRV / Water Bowser</option>
                        <option value="11" @(Model.Type==MachineType.TrackDozer        ?"selected":"")>Track Dozer</option>
                        <option value="12" @(Model.Type==MachineType.RDT               ?"selected":"")>RDT – 773 Haul Truck</option>
                        <option value="13" @(Model.Type==MachineType.TruckMountedCrane ?"selected":"")>Truck Mounted Crane</option>
                        <option value="14" @(Model.Type==MachineType.TLB              ?"selected":"")>TLB</option>
                    </select>
                </div>

                <!-- Active status -->
                <div class="form-group" style="margin:0;display:flex;align-items:center;gap:10px;padding-top:24px">
                    <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:13px">
                        <input type="checkbox" name="IsActive" value="true"
                               @(Model.IsActive ? "checked" : "")
                               style="accent-color:var(--green-go);width:16px;height:16px" />
                        <span>Active (visible to operators)</span>
                    </label>
                    <input type="hidden" name="IsActive" value="false" />
                </div>

                <!-- Description -->
                <div class="form-group" style="margin:0;grid-column:1/-1">
                    <label class="form-label">Description</label>
                    <textarea name="Description" class="form-control" rows="3"
                              maxlength="200">@Model.Description</textarea>
                </div>
            </div>

            <div style="padding:14px 24px;border-top:1px solid var(--steel-border);display:flex;justify-content:space-between;align-items:center">
                <a href="/Admin" class="btn btn-ghost">Cancel</a>
                <button type="submit" class="btn btn-primary" style="min-width:120px">
                    Save Changes
                </button>
            </div>
        </form>
    </div>
</div>
