@model List<EquipmentChecklist.Models.DefectOrder>
@using EquipmentChecklist.Models
@{
    ViewData["Title"] = "Parts Cart";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var cart = ViewBag.Cart as List<EquipmentChecklist.Controllers.CartItem> ?? new();
}

<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px">
    <div>
        <a href="/Mechanic" class="btn btn-ghost" style="margin-bottom:8px">← Back to Defects</a>
        <h2 class="page-title">Parts Cart</h2>
        <p class="page-subtitle">Review part details and submit — an approval email with PDF will be sent to the manager.</p>
    </div>
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <div class="empty-icon">🛒</div>
        <h3>Cart is empty</h3>
        <p>Add defect items from the Defect Orders page.</p>
        <a href="/Mechanic" class="btn btn-primary" style="margin-top:16px">← Back to Defects</a>
    </div>
}
else
{
    <!-- ── Remove forms (standalone, OUTSIDE the submit form) ── -->
    @for (int i = 0; i < Model.Count; i++)
    {
        <form id="removeForm_@Model[i].Id" method="post" action="/Mechanic/RemoveFromCart" style="display:none">
            @Html.AntiForgeryToken()
            <input type="hidden" name="defectOrderId" value="@Model[i].Id" />
        </form>
    }

    <!-- ── Main submit form ──────────────────────────────────── -->
    <form method="post" action="/Mechanic/SubmitCartOrders">
        @Html.AntiForgeryToken()

        <div style="background:var(--steel-mid);border:1px solid var(--steel-border);border-radius:10px;overflow:hidden;margin-bottom:20px">
            <div style="padding:12px 20px;border-bottom:1px solid var(--steel-border);background:var(--steel-dark);display:flex;justify-content:space-between;align-items:center">
                <h3 style="font-size:14px;font-weight:700;text-transform:uppercase;letter-spacing:.08em">
                    @Model.Count Item(s) – Enter Part Details
                </h3>
                <span style="font-size:12px;color:var(--amber)">
                    📧 A PDF order will be emailed to the manager on submission
                </span>
            </div>

            @for (int i = 0; i < Model.Count; i++)
            {
                var d = Model[i];
                <input type="hidden" name="orders[@i].DefectOrderId" value="@d.Id" />

                <div style="padding:16px 20px;border-bottom:1px solid var(--steel-border)">
                    <div style="display:flex;justify-content:space-between;align-items:start;margin-bottom:12px;flex-wrap:wrap;gap:8px">
                        <div>
                            <strong style="font-size:14px">@d.SubmissionItem.TemplateItem.ItemName</strong>
                            @if (d.SubmissionItem.TemplateItem.IsNoGoItem)
                            {
                                <span class="badge badge-nogo" style="margin-left:6px;font-size:9px">CRITICAL</span>
                            }
                            <div style="font-size:12px;color:var(--text-muted);margin-top:2px">
                                Machine: <strong>@d.Submission.Machine.MachineNumber</strong> – @d.Submission.Machine.MachineName
                            </div>
                            @if (d.SubmissionItem.Notes != null)
                            {
                                <div style="font-size:12px;color:var(--amber);margin-top:2px;font-style:italic">
                                    Defect note: @d.SubmissionItem.Notes
                                </div>
                            }
                        </div>

                        <!-- Remove triggers the standalone form via JS — no nesting needed -->
                        <button type="button"
                                onclick="document.getElementById('removeForm_@d.Id').submit()"
                                class="btn btn-ghost btn-sm"
                                style="color:var(--red-nogo);border-color:var(--red-dark)">
                            ✕ Remove
                        </button>
                    </div>

                    <div style="display:grid;grid-template-columns:1fr auto;gap:12px">
                        <div class="form-group" style="margin:0">
                            <label class="form-label">Part Required <span style="color:var(--red-nogo)">*</span></label>
                            <input type="text" name="orders[@i].PartRequired" class="form-control"
                                   placeholder="e.g. Hydraulic Cylinder Seal Kit" required />
                        </div>
                        <div class="form-group" style="margin:0">
                            <label class="form-label">Part Number (optional)</label>
                            <input type="text" name="orders[@i].PartNumber" class="form-control"
                                   placeholder="e.g. CAT-4552-HYD" style="width:160px" />
                        </div>
                    </div>
                </div>
            }
        </div>

        <div style="display:flex;gap:12px;align-items:center">
            <button type="submit" class="btn btn-primary" style="padding:12px 28px">
                📦 Submit @Model.Count Part Order(s) &amp; Notify Manager
            </button>
            <a href="/Mechanic" class="btn btn-ghost">Cancel</a>
        </div>
    </form>
}
